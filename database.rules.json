{
  "rules": {
    ".read": false,
    ".write": false,

    "preCadastros": {
      ".read": false,
      ".write": false
    },

    "usuariosByUid": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "usuarios": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      "$emailKey": {
        ".read": "auth != null && (root.child('usuarios').child($emailKey).child('uid').val() === auth.uid || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "clientesFinanceiro": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      "$clientId": {
        ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('clienteId').val() === $clientId || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "auditLogs": {
      ".read": "auth != null && root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master'",
      "$logId": {
        ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid && newData.child('email').val() === auth.token.email"
      }
    },

    "configuracoes": {
      "paginaInicial": {
        ".read": true,
        ".write": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')"
      },
      "pagamento": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master'",
        "diasNovidadesVisiveis": {
          ".read": true
        }
      },
      "novidades": {
        ".read": true,
        ".write": "auth != null && root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master'"
      },
      "$other": {
        ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master'"
      }
    },

    "cliquesPorBotao": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "metricasClientes": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true,
      "$clientKey": {
        ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin' || root.child('usuariosByUid').child(auth.uid).child('clienteId').val() === $clientKey || root.child('clientes').child(root.child('usuariosByUid').child(auth.uid).child('clienteId').val()).child('nomeNormalizado').val() === $clientKey || root.child('clientes').child(root.child('usuariosByUid').child(auth.uid).child('clienteId').val()).child('aliases').child($clientKey).val() === true)"
      }
    },

    "noticias": {
      ".read": true,
      "$newsId": {
        ".write": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && newData.child('createdBy').val() === auth.uid) || (data.child('createdBy').val() === auth.uid && (!newData.exists() || newData.child('createdBy').val() === auth.uid)))"
      }
    },

    "cliquesMenuLateral": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "acessosPorDia": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesCardapiosOndeComer": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesWhatsOndeComer": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesFotosOndeComer": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesPromocoesPorComercio": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesPorBotaoDetalhado": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesOndeComerDetalhado": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesPromocoesDetalhado": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "cliquesPorMenu": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "origemAcessos": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "instalacoesPWA": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "usoPWA": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "usuariosUnicos": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "onlineUserHistory": {
      ".read": "auth != null && root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master'",
      ".write": true
    },

    "acessos": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "imoveisCliquesPorDia": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "imoveisCliquesResumo": {
      ".read": "auth != null && (root.child('usuariosByUid').child(auth.uid).child('role').val() === 'master' || root.child('usuariosByUid').child(auth.uid).child('role').val() === 'admin')",
      ".write": true
    },

    "$other": {
      ".read": "$other !== 'onlineUserHistory'",
      ".write": true
    }
  }
}
