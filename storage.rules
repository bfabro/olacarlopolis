rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 8 * 1024 * 1024;
    }

    function isPdf() {
      return request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /clientes/{clientId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && (isImage() || isPdf());
    }

    match /conteudosInformativos/{module}/{itemId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && (isImage() || isPdf());
    }

    match /eventos/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /configuracoes/paginaInicial/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
